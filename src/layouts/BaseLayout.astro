---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A complete, always-current catalog of free perks available to Dartmouth students and alumni." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/tokens.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- Nav: N7 Inline + Wordmark -->
    <header>
      <nav class="nav-inline" aria-label="Primary">
        <div class="nav-container">
          <a href="/" class="wordmark">Free Stuff @ Dartmouth</a>
          <div class="nav-links">
            <a href="/for-students" class="nav-link">Students</a>
            <a href="/for-alumni" class="nav-link">Alumni</a>
            <a href="/scenarios" class="nav-link">Scenarios</a>
            <a href="/submit" class="nav-link">Submit</a>
            <a href="/about" class="nav-link">About</a>
          </div>
        </div>
      </nav>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <!-- Footer: Ft2 Terse statement -->
    <footer class="footer-terse">
      <div class="footer-container">
        <p>Built by Dartmouth folks, for Dartmouth folks. <a href="https://github.com/sarakay/freestuff-dartmouth-v2" class="footer-link">Fork this for your school</a>.</p>
        <p class="footer-disclosure">An independent, community-maintained catalog — not an official Dartmouth site. Always verify access details on the linked Dartmouth page.</p>
        <p class="footer-links">
          <a href="/privacy" class="footer-link">Privacy</a> ·
          <a href="/terms" class="footer-link">Terms</a> ·
          <a href="/about" class="footer-link">About</a>
        </p>
      </div>
    </footer>

    <!-- Inline status messages (replaces native alert/confirm) -->
    <div id="toast-region" class="toast-region" role="status" aria-live="polite"></div>

    <style>
      /* Nav: N7 Inline + Wordmark */
      .nav-inline {
        border-top: 4px solid var(--color-accent);
        border-bottom: var(--rule-thin) solid var(--color-border);
        background: var(--color-paper);
      }

      .nav-container {
        max-width: 90rem;
        margin: 0 auto;
        padding: var(--space-md) var(--space-lg);
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-md);
      }

      .nav-links {
        display: flex;
        align-items: baseline;
        gap: var(--space-md);
      }

      .wordmark {
        font-family: var(--font-display);
        font-style: italic;
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--color-accent);
        text-decoration: none;
        transition: color var(--dur-fast) var(--ease-out);
      }

      .wordmark:hover {
        color: var(--color-accent-hover);
      }

      .nav-link {
        font-size: var(--text-base);
        color: var(--color-ink-muted);
        text-decoration: none;
        transition: color var(--dur-fast) var(--ease-out);
        white-space: nowrap;
      }

      .nav-link:hover {
        color: var(--color-accent);
      }

      @media (max-width: 768px) {
        .nav-container {
          padding: var(--space-sm) var(--space-md);
          gap: var(--space-sm);
        }

        .wordmark {
          font-size: var(--text-lg);
        }

        .nav-link {
          font-size: var(--text-sm);
        }
      }

      /* Footer: Ft2 Terse statement */
      .footer-terse {
        margin-top: var(--space-4xl);
        padding: var(--space-xl) var(--space-lg);
        border-top: var(--rule-thin) solid var(--color-border);
        background: var(--color-paper-2);
      }

      .footer-container {
        max-width: 90rem;
        margin: 0 auto;
      }

      .footer-terse p {
        margin: 0;
        font-size: var(--text-sm);
        color: var(--color-ink-muted);
        line-height: var(--leading-relaxed);
      }

      .footer-disclosure {
        margin-top: var(--space-2xs) !important;
        font-size: var(--text-xs) !important;
        color: var(--color-ink-subtle) !important;
      }

      .footer-links {
        margin-top: var(--space-xs) !important;
        font-size: var(--text-sm) !important;
      }

      .footer-link {
        color: var(--color-accent);
        text-decoration: none;
        transition: color var(--dur-fast) var(--ease-out);
      }

      .footer-link:hover {
        color: var(--color-accent-hover);
        text-decoration: underline;
      }

      @media (max-width: 768px) {
        .footer-terse {
          padding: var(--space-lg) var(--space-md);
        }
      }
    </style>
  </body>
</html>
