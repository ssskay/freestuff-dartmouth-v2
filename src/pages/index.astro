---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { getAllResources } from '../lib/supabase';

// Fetch resources from Supabase
// Fallback to static JSON if Supabase is not configured
let resources;
try {
  resources = await getAllResources();
  if (resources.length === 0) {
    // Fallback to static data if database is empty
    const staticResources = await import('../content/resources.json');
    resources = staticResources.default.map(r => ({
      ...r,
      url: r.link,
      upvotes: 0,
      is_active: r.status === 'active'
    }));
  }
} catch (error) {
  console.error('Error fetching from Supabase, using static data:', error);
  const staticResources = await import('../content/resources.json');
  resources = staticResources.default.map(r => ({
    ...r,
    url: r.link,
    upvotes: 0,
    is_active: r.status === 'active'
  }));
}

// Get unique categories and eligibility options
const categories = [...new Set(resources.map(r => r.category))].sort();
const eligibilityOptions = [...new Set(resources.flatMap(r => r.eligibility))].sort();

// Filter hidden gems
const hiddenGems = resources.filter(r => r.hidden_gem === true);

// Calculate total annual value
const totalValue = resources
  .filter(r => r.annual_value && r.annual_value > 0)
  .reduce((sum, r) => sum + r.annual_value, 0);

// Get recently added resources (last 30 days)
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const recentResources = resources
  .filter(r => r.date_added && new Date(r.date_added) >= thirtyDaysAgo)
  .sort((a, b) => new Date(b.date_added).getTime() - new Date(a.date_added).getTime())
  .slice(0, 3);
---

<BaseLayout title="Free Stuff @ Dartmouth">
  <div class="hero-catalogue">
    <h1 class="hero-title">Your complete catalog of free perks</h1>
    <p class="hero-deck">
      Dartmouth students and alumni pay for way more than they use. This is everything you already have access to — <strong>{resources.length} verified resources</strong> across software, news, libraries, outdoor gear, career services, and more.
    </p>

    <!-- Search -->
    <div class="search-wrapper">
      <input
        type="text"
        id="search"
        placeholder="Search resources..."
        class="search-input"
      />
    </div>

    <!-- Filters -->
    <div class="filter-bar">
      <div class="filter-controls">
        <div class="filter-group">
          <label for="category-filter" class="filter-label">Category</label>
          <select id="category-filter" class="filter-select">
            <option value="">All categories</option>
            {categories.map((cat) => (
              <option value={cat}>{cat.replace(/-/g, ' ')}</option>
            ))}
          </select>
        </div>

        <div class="filter-group">
          <label for="eligibility-filter" class="filter-label">Eligibility</label>
          <select id="eligibility-filter" class="filter-select">
            <option value="">All eligibility</option>
            {eligibilityOptions.map((elig) => (
              <option value={elig}>{elig}</option>
            ))}
          </select>
        </div>

        <div class="filter-group">
          <label for="sort-filter" class="filter-label">Sort by</label>
          <select id="sort-filter" class="filter-select">
            <option value="name">Name (A-Z)</option>
            <option value="popular">Most Popular</option>
            <option value="value">Highest Value</option>
            <option value="recent">Recently Added</option>
          </select>
        </div>
      </div>

      <div class="filter-status">
        <p class="result-count">
          Showing <span id="result-count">{resources.length}</span>
        </p>
        <button id="clear-filters" class="clear-btn">Clear filters</button>
      </div>
    </div>
  </div>

  <!-- Value Calculator Banner -->
  <div class="value-banner">
    <div class="value-banner-content">
      <div class="value-amount">${totalValue.toLocaleString()}</div>
      <div class="value-label">in free resources you already have access to</div>
    </div>
  </div>

  <!-- Recently Added Section -->
  {recentResources.length > 0 && (
    <div class="recently-added-section">
      <h3 class="recently-added-title">Just added</h3>
      <div class="recently-added-grid">
        {recentResources.map((resource) => (
          <a href={resource.url} target="_blank" rel="noopener noreferrer" class="recently-added-item">
            <span class="new-badge">New</span>
            <span class="recently-added-name">{resource.name}</span>
            <span class="recently-added-category">{resource.category.replace(/-/g, ' ')}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Hidden Gems Section -->
  {hiddenGems.length > 0 && (
    <div class="hidden-gems-section">
      <div class="hidden-gems-header">
        <h2 class="hidden-gems-title">The stuff nobody tells you about</h2>
        <p class="hidden-gems-deck">
          Most people graduate without knowing half of this exists. DOC cabins for $20/night? Bloomberg Terminals you can just walk up and use? Your friend who reads the fine print found these for you.
        </p>
      </div>
      <div class="hidden-gems-grid">
        {hiddenGems.map((resource) => (
          <div class="hidden-gem-card">
            <ResourceCard resource={resource} />
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Resource Grid -->
  <div id="resource-grid" class="resource-grid">
    {resources.map((resource) => (
      <div class="resource-item"
           data-category={resource.category}
           data-eligibility={JSON.stringify(resource.eligibility)}
           data-searchable={JSON.stringify({
             name: resource.name.toLowerCase(),
             description: resource.description.toLowerCase(),
             category: resource.category.toLowerCase(),
           })}>
        <ResourceCard resource={resource} />
      </div>
    ))}
  </div>

  <div id="no-results" class="no-results hidden">
    <p class="no-results-text">No resources found matching your filters.</p>
    <button id="clear-filters-alt" class="clear-btn-alt">Clear filters and try again</button>
  </div>

  <style>
    /* Hero — Catalogue macrostructure */
    .hero-catalogue {
      max-width: 90rem;
      margin: 0 auto;
      padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
    }

    .hero-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-display);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-md) 0;
      max-width: var(--measure-narrow);
    }

    .hero-deck {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      margin: 0 0 var(--space-xl) 0;
      max-width: var(--measure);
    }

    .hero-deck strong {
      color: var(--color-ink);
      font-weight: 600;
    }

    /* Search */
    .search-wrapper {
      margin-bottom: var(--space-lg);
    }

    .search-input {
      width: 100%;
      padding: var(--space-sm) var(--space-md);
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: var(--leading-normal);
      color: var(--color-ink);
      background: var(--color-paper);
      border: var(--rule-thin) solid var(--color-border);
      border-radius: var(--radius-md);
      transition: border-color var(--dur-fast) var(--ease-out),
                  box-shadow var(--dur-fast) var(--ease-out);
    }

    .search-input::placeholder {
      color: var(--color-ink-subtle);
    }

    .search-input:hover {
      border-color: var(--color-border-strong);
    }

    .search-input:focus {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px var(--color-accent-subtle);
    }

    /* Filter bar */
    .filter-bar {
      padding: var(--space-lg);
      background: var(--color-paper-2);
      border: var(--rule-thin) solid var(--color-border);
      border-radius: var(--radius-md);
      margin-bottom: var(--space-2xl);
    }

    .filter-controls {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: var(--space-md);
      margin-bottom: var(--space-md);
    }

    .filter-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xs);
      min-width: 0;
    }

    .filter-label {
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--color-ink-muted);
    }

    .filter-select {
      padding: var(--space-xs) var(--space-sm);
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-ink);
      background: var(--color-paper);
      border: var(--rule-thin) solid var(--color-border);
      border-radius: var(--radius-sm);
      transition: border-color var(--dur-fast) var(--ease-out);
      min-width: 0;
    }

    .filter-select:hover {
      border-color: var(--color-border-strong);
    }

    .filter-select:focus {
      border-color: var(--color-accent);
    }

    .filter-status {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: var(--space-md);
      border-top: var(--rule-thin) solid var(--color-border);
      gap: var(--space-md);
      flex-wrap: wrap;
    }

    .result-count {
      margin: 0;
      font-size: var(--text-sm);
      color: var(--color-ink-muted);
    }

    .result-count span {
      font-weight: 600;
      color: var(--color-ink);
    }

    .clear-btn,
    .clear-btn-alt {
      padding: 0;
      font-family: var(--font-body);
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--color-accent);
      background: none;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: color var(--dur-fast) var(--ease-out);
      white-space: nowrap;
    }

    .clear-btn:hover,
    .clear-btn-alt:hover {
      color: var(--color-accent-hover);
      text-decoration: underline;
    }

    /* Resource grid */
    .resource-grid {
      max-width: 90rem;
      margin: 0 auto;
      padding: 0 var(--space-lg) var(--space-2xl);
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
      gap: var(--space-lg);
    }

    /* No results */
    .no-results {
      max-width: 90rem;
      margin: 0 auto;
      padding: var(--space-3xl) var(--space-lg);
      text-align: center;
    }

    .no-results.hidden {
      display: none;
    }

    .no-results-text {
      margin: 0 0 var(--space-md) 0;
      font-size: var(--text-lg);
      color: var(--color-ink-muted);
    }

    .clear-btn-alt {
      font-size: var(--text-base);
    }

    /* Value Calculator Banner */
    .value-banner {
      max-width: 90rem;
      margin: 0 auto var(--space-2xl);
      padding: 0 var(--space-lg);
    }

    .value-banner-content {
      padding: var(--space-xl);
      background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-hover) 100%);
      border-radius: var(--radius-md);
      text-align: center;
    }

    .value-amount {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-4xl);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-paper);
      margin-bottom: var(--space-2xs);
    }

    .value-label {
      font-size: var(--text-lg);
      line-height: var(--leading-normal);
      color: var(--color-paper);
      opacity: 0.95;
    }

    /* Recently Added Section */
    .recently-added-section {
      max-width: 90rem;
      margin: 0 auto var(--space-2xl);
      padding: 0 var(--space-lg);
    }

    .recently-added-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-xl);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-md) 0;
    }

    .recently-added-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
      gap: var(--space-sm);
    }

    .recently-added-item {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: var(--space-3xs);
      padding: var(--space-sm) var(--space-md);
      background: var(--color-paper);
      border: var(--rule-thin) solid var(--color-border);
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: border-color var(--dur-fast) var(--ease-out);
    }

    .recently-added-item:hover {
      border-color: var(--color-accent);
    }

    .new-badge {
      position: absolute;
      top: var(--space-xs);
      right: var(--space-xs);
      padding: var(--space-3xs) var(--space-xs);
      font-size: var(--text-xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-paper);
      background: var(--color-accent);
      border-radius: var(--radius-sm);
    }

    .recently-added-name {
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--color-ink);
      padding-right: var(--space-xl);
    }

    .recently-added-category {
      font-size: var(--text-xs);
      text-transform: capitalize;
      color: var(--color-ink-subtle);
    }

    /* Hidden Gems Section */
    .hidden-gems-section {
      max-width: 90rem;
      margin: 0 auto var(--space-3xl);
      padding: 0 var(--space-lg);
    }

    .hidden-gems-header {
      max-width: var(--measure);
      margin-bottom: var(--space-xl);
    }

    .hidden-gems-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-2xl);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-xs) 0;
    }

    .hidden-gems-deck {
      font-size: var(--text-base);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      margin: 0;
    }

    .hidden-gems-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
      gap: var(--space-lg);
    }

    .hidden-gem-card {
      position: relative;
    }

    .hidden-gem-card::before {
      content: '';
      position: absolute;
      top: -4px;
      left: -4px;
      right: -4px;
      bottom: -4px;
      background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-hover) 100%);
      border-radius: var(--radius-md);
      opacity: 0.1;
      pointer-events: none;
      z-index: -1;
    }

    /* Mobile adjustments */
    @media (max-width: 768px) {
      .hero-catalogue {
        padding: var(--space-2xl) var(--space-md) var(--space-xl);
      }

      .hero-title {
        font-size: var(--text-3xl);
      }

      .hero-deck {
        font-size: var(--text-base);
      }

      .filter-bar {
        padding: var(--space-md);
      }

      .filter-controls {
        grid-template-columns: 1fr;
        gap: var(--space-sm);
      }

      .filter-status {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-xs);
      }

      .hidden-gems-section {
        padding: 0 var(--space-md);
        margin-bottom: var(--space-2xl);
      }

      .hidden-gems-title {
        font-size: var(--text-xl);
      }

      .hidden-gems-deck {
        font-size: var(--text-sm);
      }

      .value-banner {
        padding: 0 var(--space-md);
        margin-bottom: var(--space-xl);
      }

      .value-banner-content {
        padding: var(--space-lg);
      }

      .value-amount {
        font-size: var(--text-3xl);
      }

      .value-label {
        font-size: var(--text-base);
      }

      .recently-added-section {
        padding: 0 var(--space-md);
        margin-bottom: var(--space-xl);
      }

      .recently-added-title {
        font-size: var(--text-lg);
      }

      .recently-added-grid {
        grid-template-columns: 1fr;
      }

      .hidden-gems-grid {
        gap: var(--space-md);
        grid-template-columns: 1fr;
      }

      .resource-grid {
        padding: 0 var(--space-md) var(--space-xl);
        gap: var(--space-md);
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    import { getFingerprint } from '../lib/fingerprint';
    import { upvoteResource, removeUpvote, getUserVotes } from '../lib/supabase';

    // Client-side filtering and search
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
    const eligibilityFilter = document.getElementById('eligibility-filter') as HTMLSelectElement;
    const sortFilter = document.getElementById('sort-filter') as HTMLSelectElement;
    const clearFiltersBtn = document.getElementById('clear-filters') as HTMLButtonElement;
    const clearFiltersBtnAlt = document.getElementById('clear-filters-alt') as HTMLButtonElement;
    const resultCount = document.getElementById('result-count') as HTMLSpanElement;
    const resourceGrid = document.getElementById('resource-grid') as HTMLDivElement;
    const noResults = document.getElementById('no-results') as HTMLDivElement;
    let resourceItems = Array.from(document.querySelectorAll('.resource-item') as NodeListOf<HTMLDivElement>);

    function sortResources() {
      const sortBy = sortFilter.value;

      resourceItems.sort((a, b) => {
        const aCard = a.querySelector('.resource-card');
        const bCard = b.querySelector('.resource-card');

        if (sortBy === 'popular') {
          const aUpvotes = parseInt(aCard?.querySelector('.upvote-count')?.textContent || '0');
          const bUpvotes = parseInt(bCard?.querySelector('.upvote-count')?.textContent || '0');
          return bUpvotes - aUpvotes;
        } else if (sortBy === 'value') {
          const aValue = aCard?.querySelector('.value-badge')?.textContent?.replace(/[^0-9]/g, '') || '0';
          const bValue = bCard?.querySelector('.value-badge')?.textContent?.replace(/[^0-9]/g, '') || '0';
          return parseInt(bValue) - parseInt(aValue);
        } else if (sortBy === 'recent') {
          const aNew = aCard?.querySelector('.new-badge') ? 1 : 0;
          const bNew = bCard?.querySelector('.new-badge') ? 1 : 0;
          if (aNew !== bNew) return bNew - aNew;
          const aName = JSON.parse(a.dataset.searchable || '{}').name || '';
          const bName = JSON.parse(b.dataset.searchable || '{}').name || '';
          return aName.localeCompare(bName);
        } else { // name
          const aName = JSON.parse(a.dataset.searchable || '{}').name || '';
          const bName = JSON.parse(b.dataset.searchable || '{}').name || '';
          return aName.localeCompare(bName);
        }
      });

      // Re-append elements in sorted order
      resourceItems.forEach(item => resourceGrid.appendChild(item));
    }

    function filterResources() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedCategory = categoryFilter.value;
      const selectedEligibility = eligibilityFilter.value;

      let visibleCount = 0;

      resourceItems.forEach((item) => {
        const category = item.dataset.category || '';
        const eligibility = JSON.parse(item.dataset.eligibility || '[]');
        const searchable = JSON.parse(item.dataset.searchable || '{}');

        const matchesSearch = !searchTerm ||
          searchable.name.includes(searchTerm) ||
          searchable.description.includes(searchTerm) ||
          searchable.category.includes(searchTerm);

        const matchesCategory = !selectedCategory || category === selectedCategory;
        const matchesEligibility = !selectedEligibility || eligibility.includes(selectedEligibility);

        if (matchesSearch && matchesCategory && matchesEligibility) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      resultCount.textContent = visibleCount.toString();

      if (visibleCount === 0) {
        resourceGrid.classList.add('hidden');
        noResults.classList.remove('hidden');
      } else {
        resourceGrid.classList.remove('hidden');
        noResults.classList.add('hidden');
      }
    }

    function clearFilters() {
      searchInput.value = '';
      categoryFilter.value = '';
      eligibilityFilter.value = '';
      sortFilter.value = 'name';
      sortResources();
      filterResources();
    }

    searchInput.addEventListener('input', filterResources);
    categoryFilter.addEventListener('change', filterResources);
    eligibilityFilter.addEventListener('change', filterResources);
    sortFilter.addEventListener('change', sortResources);
    clearFiltersBtn.addEventListener('click', clearFilters);
    clearFiltersBtnAlt.addEventListener('click', clearFilters);

    // Initial sort
    sortResources();

    // Upvote functionality
    const fingerprint = getFingerprint();

    // Get user's existing votes and update UI
    getUserVotes(fingerprint).then(votedIds => {
      votedIds.forEach(id => {
        const btn = document.querySelector(`button[data-resource-id="${id}"]`) as HTMLButtonElement;
        if (btn) {
          btn.dataset.voted = 'true';
        }
      });
    });

    // Handle upvote button clicks
    document.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const button = target.closest('.upvote-btn') as HTMLButtonElement;

      if (!button) return;

      e.preventDefault();

      const resourceId = button.dataset.resourceId;
      const hasVoted = button.dataset.voted === 'true';

      if (!resourceId) return;

      // Disable button during request
      button.disabled = true;

      try {
        let result;
        if (hasVoted) {
          result = await removeUpvote(resourceId, fingerprint);
        } else {
          result = await upvoteResource(resourceId, fingerprint);
        }

        if (result.success) {
          // Update UI optimistically
          button.dataset.voted = hasVoted ? 'false' : 'true';
          const countSpan = button.querySelector('.upvote-count') as HTMLSpanElement;
          if (countSpan) {
            countSpan.textContent = result.upvotes.toString();
          }
        } else {
          console.warn('Vote action failed:', result.message);
        }
      } catch (error) {
        console.error('Error toggling vote:', error);
      } finally {
        button.disabled = false;
      }
    });
  </script>
</BaseLayout>
